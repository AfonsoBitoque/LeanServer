# LeanServer Production Configuration
# This file configures the HTTPS server for production deployment

# Server Configuration
host = "0.0.0.0"
port = "8443"

# TLS Configuration
tls_enabled = "true"
certificate_path = "cert.pem"
private_key_path = "key.pem"

# Connection Limits
max_connections = "1000"
max_streams = "100"

# Logging Configuration
log_level = "INFO"

# Feature Flags
enable_websocket = "true"
enable_server_push = "true"

# Crypto Backend: "native" (OpenSSL FFI, fast) or "lean" (pure Lean, verified)
crypto_backend = "lean"

# Health and Monitoring
health_check_path = "/health"
metrics_path = "/metrics"