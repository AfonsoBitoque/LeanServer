# Configuração básica do servidor HTTPS
host = "0.0.0.0"
port = "8443"
tls_enabled = "true"
max_connections = "100"
log_level = "INFO"

# Funcionalidades básicas
enable_websocket = "false"
enable_http2 = "true"
enable_metrics = "true"

# Certificados
cert_file = "cert.pem"
key_file = "key.pem"

# Endpoints padrão
health_check_path = "/health"
metrics_path = "/metrics"